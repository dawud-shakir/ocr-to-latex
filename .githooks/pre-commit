#!/usr/bin/env bash

# Block staged files larger than this many bytes.
# GitHub hard limit is 100 MiB, so 95 MiB gives a safety margin.
MAX_SIZE=$((95 * 1024 * 1024))

failed=0

# Check added/copied/modified/renamed staged files.
while IFS= read -r -d '' file; do
    # Skip if file no longer exists in index
    if ! git cat-file -e ":$file" 2>/dev/null; then
        continue
    fi

    size=$(git cat-file -s ":$file")

    if [ "$size" -gt "$MAX_SIZE" ]; then
        size_mb=$(awk "BEGIN {printf \"%.2f\", $size / 1024 / 1024}")
        max_mb=$(awk "BEGIN {printf \"%.2f\", $MAX_SIZE / 1024 / 1024}")

        echo "ERROR: Staged file is too large:"
        echo "  $file"
        echo "  Size: ${size_mb} MiB"
        echo "  Limit: ${max_mb} MiB"
        echo
        echo "Use Git LFS or remove it from the commit:"
        echo "  git rm --cached \"$file\""
        echo

        failed=1
    fi
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

exit "$failed"
